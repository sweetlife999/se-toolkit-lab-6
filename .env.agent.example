# LLM configuration for agent.py
# Copy this file: cp .env.agent.example .env.agent.secret
#
# NOTE: This is NOT the backend API_KEY from .env.docker.secret.
# That key protects your LMS endpoints.
# This file configures the LLM that powers your agent.

# Your LLM provider API key
# For Qwen Code API: the QWEN_API_KEY you set in ~/qwen-code-oai-proxy/.env
# For OpenRouter: your OpenRouter API key
LLM_API_KEY="your-llm-api-key-here"

# API base URL (OpenAI-compatible endpoint)
# For Qwen Code API on your VM, use: http://localhost:42005/v1
# For OpenRouter, use: https://openrouter.ai/api/v1
LLM_API_BASE="https://openrouter.ai/api/v1"

# Model name
# For Qwen Code API, use: qwen3-coder-plus
# For OpenRouter, use: meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL="meta-llama/llama-3.3-70b-instruct:free"
